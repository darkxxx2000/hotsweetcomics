<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Comic</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<style>
body{background:#000;color:#fff;font-family:Arial;margin:0;padding:30px;}
.header{display:flex;gap:20px;}
.header img{width:280px;border-radius:8px;}
.chapter{margin:10px 0;}
.chapter a{color:#ff66aa;text-decoration:none;font-size:18px;}
</style>
</head>
<body>

<div id="comic"></div>

<script>
const id=new URLSearchParams(location.search).get('id');

fetch('data.json').then(r=>r.json()).then(data=>{
  const comic=data.comics[id];

  document.getElementById('comic').innerHTML=`
    <div class="header">
      <img src="${comic.cover}">
      <div>
        <h1>${comic.title}</h1>
        <p>${comic.desc}</p>
      </div>
    </div>

    <h2>Chapters</h2>
    ${comic.chapters.map(ch=>`
      <div class="chapter">
        <a href="chapter.html?id=${ch.id}">${ch.title}</a>
      </div>
    `).join('')}
  `;
});
</script>

</body>
</html>
